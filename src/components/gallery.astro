---
const res = await fetch("https://worker.stixvish.com/images");
const photos: { url: string; alt: string; width: number; height: number }[] =
  await res.json();
---

<!-- photo strip -->
<section id="photo-strip" class="smooth-entry w-full overflow-hidden">
  <div id="photo-strip-inner" class="flex w-max gap-4 opacity-0">
    {
      [...photos, ...photos].map((photo) => (
        <img
          src={photo.url}
          alt={photo.alt}
          width={photo.width}
          height={photo.height}
          draggable="false"
          class="pointer-events-none h-[clamp(20rem,22dvw,30rem)] w-auto shrink-0 rounded-2xl object-cover"
          loading="eager"
        />
      ))
    }
  </div>
</section>

<style>
  @keyframes p-scroll {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0%);
    }
  }

  .photo-scroll {
    animation: p-scroll 60s linear infinite;
  }
</style>

<script>
  const strip = document.getElementById("photo-strip");
  const stripInner = document.getElementById("photo-strip-inner");
  const images = stripInner?.querySelectorAll("img") ?? [];
  const total = images.length;
  let loaded = 0;

  function onLoad() {
    loaded++;
    if (loaded === total && strip && stripInner) {
      stripInner.classList.add("photo-scroll");
      strip.classList.add(".smooth-entry");
      stripInner.classList.remove("opacity-0");
    }
  }

  images.forEach((img) => {
    if (img.complete) {
      onLoad();
    } else {
      img.addEventListener("load", onLoad);
    }
  });
</script>
